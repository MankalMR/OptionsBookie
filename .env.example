# ============================================================
# OptionsBookie — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# ============================================================

# ---------- Server Configuration ----------
# Optional: Port to run the server on (defaults to 3007)
PORT=3007
NODE_ENV=development

# ---------- NextAuth.js ----------
# Required: Base URL for NextAuth callbacks (set to your deployed URL in production)
NEXTAUTH_URL=http://localhost:3007
# Required: Secret used to sign/encrypt tokens (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=

# ---------- Supabase ----------
# Required: Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=
# Required: Supabase anonymous (public) key
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required: Supabase service role key (server-side only, used by NextAuth adapter)
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Google OAuth ----------
# Required: Google OAuth 2.0 credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- SEO & Site Identity ----------
# Required: Canonical site URL (used for metadata, OG images, canonical links)
NEXT_PUBLIC_SITE_URL=your-site-url
# Optional: Site name override (defaults to 'OptionsBookie')
NEXT_PUBLIC_SITE_NAME=
# Optional: Site description override
NEXT_PUBLIC_SITE_DESCRIPTION=
# Optional: Site keywords override (comma-separated)
NEXT_PUBLIC_SITE_KEYWORDS=
# Optional: Author information
NEXT_PUBLIC_AUTHOR_NAME=Manohar Mankala
NEXT_PUBLIC_AUTHOR_URL=https://mankala.space
NEXT_PUBLIC_AUTHOR_EMAIL=manohar.mankala@gmail.com

# Optional: Google Search Console verification token
GOOGLE_SITE_VERIFICATION=
# Optional: Other search engine verifications
YANDEX_VERIFICATION=
YAHOO_VERIFICATION=

# ---------- Market Data APIs ----------
# Optional: Alpha Vantage API key (for stock prices and historical data)
ALPHA_VANTAGE_KEY=
# Optional: Finnhub API key (for real-time quotes)
FINNHUB_API_KEY=

# ---------- AI / Gemini ----------
# Optional: Google Gemini API key (enables AI-powered price analysis/fetching)
GEMINI_API_KEY=
# Optional: Gemini model override (defaults to 'gemini-2.5-flash')
GEMINI_MODEL=gemini-2.5-flash

# ---------- Email Notifications (Resend) ----------
# Optional: Resend API key (from https://resend.com)
RESEND_API_KEY=
# Optional: Custom sender email
NOTIFICATION_SENDER_EMAIL=
# Optional: Custom sender display name
NOTIFICATION_SENDER_NAME=
# Optional: Reply-to email address
NOTIFICATION_REPLY_TO_EMAIL=

# ---------- Cron Jobs ----------
# Optional: Secret to authenticate cron job requests
CRON_SECRET=

# ---------- Calculation Engine ----------
# Optional: Method for Annualized RoR calculation ('time-period' or 'trade-weighted')
ANN_ROR_TYPE=time-period

# ---------- Demo Mode ----------
# Optional: Set to '1' to enable the demo mode feature
ENABLE_DEMO_MODE=0
# Optional: Demo session TTL in hours (defaults to 2)
DEMO_SESSION_TTL_HOURS=2
# Optional: Max concurrent demo sessions (defaults to 100)
DEMO_MAX_SESSIONS=100
# Optional: Rate limit for demo sessions in requests per minute (defaults to 30)
DEMO_RATE_LIMIT_RPM=30

# ---------- Debug ----------
# Optional: Set to '1' to enable verbose debug logging
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=0
